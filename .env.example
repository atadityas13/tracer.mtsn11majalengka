APP_NAME=TRACER MTsN 11 Majalengka

# URL aplikasi (tanpa trailing slash)
# Contoh produksi cPanel:
APP_URL=https://e-leger.mtsn11majalengka.sch.id

# Konfigurasi database (isi sesuai MySQL Databases di cPanel)
# Umumnya DB_NAME dan DB_USER memakai prefix akun cPanel, contoh: akuncpanel_eleger
DB_HOST=localhost
DB_PORT=3306
DB_NAME=akuncpanel_eleger
DB_USER=akuncpanel_eleger_user
DB_PASS=ganti_dengan_password_db
